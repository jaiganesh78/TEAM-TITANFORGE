  nodeTraces      String?         @db.Text // JSON string
  createdAt       DateTime        @default(now())
}

model GraphNodeOutput {
  id             String          @id @default(uuid())
  sessionId      String
  session        StrategySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
