datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String
  name           String
  role           Role           @default(MEMBER)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions       Session[]
  auditLogs      AuditLog[]
  twinAuditLogs  TwinAuditLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([email])
  @@index([organizationId])
}

model Organization {
  id         String     @id @default(uuid())
  name       String
  users      User[]
  auditLogs  AuditLog[]
  businesses Business[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id             String        @id @default(uuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  action         String
  details        String        @db.Text
  ipAddress      String?
  correlationId  String?
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([correlationId])
}

// ==========================================
// BUSINESS DIGITAL TWIN ENTITIES
// ==========================================

enum BusinessStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

model Business {
  id             String         @id @default(uuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  status         BusinessStatus @default(DRAFT)
  startedAt      DateTime       @default(now())
  lastUpdated    DateTime       @updatedAt
  completedAt    DateTime?
  deleted        Boolean        @default(false)

  // 1-to-1 Relations
  identity              BusinessIdentity?
  profile               BusinessProfile?
  model                 BusinessModel?
  marketingProfile      MarketingProfile?
  salesProfile          SalesProfile?
  operationsProfile     OperationsProfile?
  technologyProfile     TechnologyProfile?
  organizationStructure OrganizationStructure?
  discoveryProgress     DiscoveryProgress?

  // 1-to-many Relations
  revenueProfiles   RevenueProfile[]
  products          ProductPortfolio[]
  services          ServicePortfolio[]
  customerSegments  CustomerSegment[]
  customerPersonas  CustomerPersona[]
  employees         EmployeeProfile[]
  vendors           VendorProfile[]
  partners          PartnerProfile[]
  competitors       CompetitorProfile[]
  goals             BusinessGoal[]
  constraints       BusinessConstraint[]
  risks             BusinessRisk[]
  kpis              BusinessKPI[]
  documents         BusinessDocumentReference[]
  websites          WebsiteReference[]
  twinAuditLogs     TwinAuditLog[]
  answerMetadata    AnswerMetadata[]
  websiteAnalyses     Website[]
  uploadedDocuments   UploadedDocument[]
  extractedCandidates ExtractedCandidate[]
  knowledgeEntities   KnowledgeEntity[]
  businessEvidences   BusinessEvidence[]
  reviewActions       ReviewAction[]
  extractionJobs      ExtractionJob[]
  knowledgeChunks       KnowledgeChunk[]
  knowledgeCollections  KnowledgeCollection[]
  knowledgeStatistics   KnowledgeStatistics?
  knowledgeVersions     KnowledgeVersion[]
  contextSnapshots      ContextSnapshot[]

  // Growth Digital Twin Layer
  growthDomainStates    GrowthDomainState[]
  growthTwinSummary     GrowthTwinSummary?
  aiOperatingContext    AIOperatingContext?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

model BusinessProfile {
  id         String   @id @default(uuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  summary    String?  @db.Text
  vision     String?  @db.Text
  mission    String?  @db.Text
}

model BusinessIdentity {
  id           String   @id @default(uuid())
  businessId   String   @unique
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  legalName    String
  tradeName    String?
  foundedYear  Int?
  headquarters String?
  description  String?  @db.Text
  industry     String?
  websiteUrl   String?
}

model BusinessModel {
  id               String   @id @default(uuid())
  businessId       String   @unique
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type             String?
  valueProposition String?  @db.Text // JSON list in application code
  keyPartners      String?  @db.Text
  keyActivities    String?  @db.Text
  keyResources     String?  @db.Text
  costStructure    String?  @db.Text
  revenueStreams   String?  @db.Text
}

model RevenueProfile {
  id           String   @id @default(uuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  period       String
  totalRevenue Float
  mrr          Float?
  arr          Float?
  grossMargin  Float?
  growthRate   Float?
}

model ProductPortfolio {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  price       Float
  unitCost    Float?
  salesVolume Int?
}

model ServicePortfolio {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  rate        Float
  capacity    Int?
}

model CustomerSegment {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  segmentName String
  cac         Float?
  ltv         Float?
  churnRate   Float?
  description String?  @db.Text
}

model CustomerPersona {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  demographics  String?  @db.Text
  painPoints    String?  @db.Text
  coreBehaviors String?  @db.Text
}

model MarketingProfile {
  id           String   @id @default(uuid())
  businessId   String   @unique
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  adSpend      Float?
  roi          Float?
  channelsUsed String?  @db.Text
  conversions  String?  @db.Text
}

model SalesProfile {
  id             String   @id @default(uuid())
  businessId     String   @unique
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadsCount     Int?
  conversionRate Float?
  pipelineValue  Float?
  salesCycleDays Int?
}

model OperationsProfile {
  id                  String   @id @default(uuid())
  businessId          String   @unique
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  infraCost           Float?
  supportTicketsCount Int?
  avgResolutionTimeMs Int?
  bottlenecks         String?  @db.Text
}

model TechnologyProfile {
  id                    String   @id @default(uuid())
  businessId            String   @unique
  business              Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  infraProvider         String?
  coreFrameworks        String?  @db.Text
  databases             String?  @db.Text
  integrations          String?  @db.Text
  securityCertification String?
}

model OrganizationStructure {
  id           String   @id @default(uuid())
  businessId   String   @unique
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  headcount    Int?
  orgChartLink String?
}

model EmployeeProfile {
  id             String   @id @default(uuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  departmentName String
  count          Int
  avgSalary      Float?
  turnoverRate   Float?
}

model VendorProfile {
  id              String    @id @default(uuid())
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  vendorName      String
  serviceCategory String?
  contractCost    Float?
  contractEnd     DateTime?
}

model PartnerProfile {
  id              String   @id @default(uuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  partnerName     String
  partnershipType String?
  dependencyLevel String?  // LOW, MEDIUM, HIGH
}

model CompetitorProfile {
  id             String   @id @default(uuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  competitorName String
  strengths      String?  @db.Text
  weaknesses     String?  @db.Text
  marketShare    Float?
}

model BusinessGoal {
  id          String    @id @default(uuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String?   @db.Text
  targetDate  DateTime?
  progress    Float?    @default(0.0)
}

model BusinessConstraint {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type        String
  description String?  @db.Text
  limitValue  String?
}

model BusinessRisk {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  likelihood  String?  // LOW, MEDIUM, HIGH
  impact      String?  // LOW, MEDIUM, HIGH
  mitigation  String?  @db.Text
}

model BusinessKPI {
  id           String   @id @default(uuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  currentValue Float
  targetValue  Float?
  unit         String?
}

model BusinessDocumentReference {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fileName   String
  fileType   String
  fileUrl    String
  sizeBytes  Int?
  uploadedAt DateTime @default(now())
}

model WebsiteReference {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  title      String?
  description String?  @db.Text
  crawledAt  DateTime?
}

model DiscoveryProgress {
  id              String   @id @default(uuid())
  businessId      String   @unique
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  overallCoverage Float    @default(0.0)

  // Status for each of the 18 modules: DRAFT, IN_PROGRESS, COMPLETED
  identityStatus     String @default("DRAFT")
  modelStatus         String @default("DRAFT")
  productsStatus      String @default("DRAFT")
  customersStatus     String @default("DRAFT")
  marketingStatus     String @default("DRAFT")
  salesStatus         String @default("DRAFT")
  operationsStatus    String @default("DRAFT")
  financeStatus       String @default("DRAFT")
  technologyStatus    String @default("DRAFT")
  organizationStatus  String @default("DRAFT")
  partnersStatus      String @default("DRAFT")
  competitorsStatus   String @default("DRAFT")
  goalsStatus         String @default("DRAFT")
  constraintsStatus   String @default("DRAFT")
  risksStatus         String @default("DRAFT")
  kpisStatus          String @default("DRAFT")
  documentsStatus     String @default("DRAFT")
  websiteStatus       String @default("DRAFT")
}

model TwinAuditLog {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  section       String
  operation     String   // CREATE, UPDATE, DELETE
  previousValue String?  @db.Text
  newValue      String?  @db.Text
  timestamp     DateTime @default(now())

  @@index([businessId])
  @@index([userId])
}

model AnswerMetadata {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fieldPath  String   // e.g. "marketingProfile.adSpend"
  status     String   // KNOWN, ESTIMATED, UNKNOWN
  source     String   // USER, WEBSITE, DOCUMENT, AI
  updatedAt  DateTime @updatedAt

  @@unique([businessId, fieldPath])
  @@index([businessId])
}


model Website {
  id              String               @id @default(uuid())
  businessId      String
  business        Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url             String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  analysisRuns    WebsiteAnalysisRun[]

  @@index([businessId])
}

model WebsiteAnalysisRun {
  id          String                @id @default(uuid())
  websiteId   String
  website     Website               @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  status      WebsiteAnalysisStatus @default(PENDING)
  errorLogs   String?               @db.Text
  startedAt   DateTime              @default(now())
  completedAt DateTime?
  pages       WebsitePage[]
}

model WebsitePage {
  id                String             @id @default(uuid())
  analysisRunId     String
  analysisRun       WebsiteAnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
  url               String
  status            JobStatus          @default(QUEUED)
  content           String?            @db.Text
  createdAt         DateTime           @default(now())
  chunkIds          String[]
  embeddingIds      String[]
  vectorReferences  String[]
  knowledgeChunks   KnowledgeChunk[]
}

model UploadedDocument {
  id                String               @id @default(uuid())
  businessId        String
  business          Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fileName          String
  filePath          String
  fileSize          Int
  mimeType          String
  category          DocumentCategory     @default(OTHER)
  version           Int                  @default(1)
  uploadedBy        String
  hash              String
  status            DocumentStatus       @default(PENDING)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  extractions       DocumentExtraction[]
  knowledgeChunks   KnowledgeChunk[]

  @@index([businessId])
}

model DocumentExtraction {
  id                String           @id @default(uuid())
  documentId        String
  document          UploadedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  rawContent        String           @db.Text
  status            JobStatus        @default(QUEUED)
  createdAt         DateTime         @default(now())
  chunkIds          String[]
  embeddingIds      String[]
  vectorReferences  String[]
}

model ExtractedCandidate {
  id                String           @id @default(uuid())
  businessId        String
  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fieldPath         String
  value             String
  normalizedValue   String?
  confidence        Float
  sourceType        SourceType
  sourceId          String
  status            ExtractionStatus @default(PENDING_REVIEW)
  extractionMethod  String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  knowledgeChunks   KnowledgeChunk[]

  @@index([businessId])
  @@index([status])
}

model KnowledgeEntity {
  id                String       @id @default(uuid())
  businessId        String
  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  entityType        String
  fieldPath         String
  value             String
  normalizedValue   String?
  confidence        Float
  sourceType        SourceType
  sourceId          String
  evidenceId        String?
  extractionMethod  String
  reviewStatus      ReviewStatus @default(PENDING)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  chunkIds          String[]
  embeddingIds      String[]
  vectorReferences  String[]

  @@index([businessId])
}

model BusinessEvidence {
  id              String     @id @default(uuid())
  businessId      String
  business        Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fieldPath       String
  value           String
  sourceType      SourceType
  confidence      Float
  origin          String
  exactLocation   String?
  pageNumber      Int?
  sectionName     String?
  reviewer        String?
  reviewTimestamp DateTime?
  updatedAt       DateTime   @updatedAt

  @@index([businessId])
  @@index([fieldPath])
}

model ReviewAction {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  candidateId String
  action      String   // ACCEPT, REJECT, MERGE
  userId      String
  notes       String?
  createdAt   DateTime @default(now())
  knowledgeChunks KnowledgeChunk[]

  @@index([businessId])
}

model ExtractionJob {
  id              String    @id @default(uuid())
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type            String
  status          JobStatus @default(QUEUED)
  progress        Float     @default(0.0)
  errorLogs       String?   @db.Text
  executionTimeMs Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([businessId])
}

enum WebsiteAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DocumentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ExtractionStatus {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
  MERGED
}

enum ReviewStatus {
  PENDING
  REVIEWED
}

enum JobStatus {
  QUEUED
  RUNNING
  RETRY
  COMPLETED
  FAILED
  CANCELLED
}

enum SourceType {
  MANUAL
  WEBSITE
  DOCUMENT
  AI
}

enum DocumentCategory {
  FINANCIAL_REPORT
  MARKETING_REPORT
  SALES_REPORT
  BUSINESS_PLAN
  INVESTOR_PITCH_DECK
  PRODUCT_CATALOGUE
  CUSTOMER_FEEDBACK
  HR_DOCUMENTS
  OTHER
}

model KnowledgeChunk {
  id                   String               @id @default(uuid())
  businessId           String
  business             Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  source               String               // URL, filename, or "digital_twin"
  sourceType           SourceType
  section              String?
  pageNumber           Int?
  tokenCount           Int
  content              String               @db.Text
  version              Int                  @default(1)
  status               ChunkStatus          @default(ACTIVE)
  diffInfo             String?              @db.Text
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  // Immutable Lineage Tracking
  websitePageId        String?
  websitePage          WebsitePage?         @relation(fields: [websitePageId], references: [id], onDelete: Cascade)
  uploadedDocumentId   String?
  uploadedDocument     UploadedDocument?    @relation(fields: [uploadedDocumentId], references: [id], onDelete: Cascade)
  extractedCandidateId String?
  extractedCandidate   ExtractedCandidate?  @relation(fields: [extractedCandidateId], references: [id], onDelete: Cascade)
  reviewActionId       String?
  reviewAction         ReviewAction?        @relation(fields: [reviewActionId], references: [id], onDelete: Cascade)
  fieldPath            String?              // Twin field reference
  recommendationId     String?              // Future recommendation reference

  // Version tracking & historical retrieval
  previousChunkId      String?
  previousChunk        KnowledgeChunk?      @relation("ChunkHistory", fields: [previousChunkId], references: [id], onDelete: SetNull)
  nextChunks           KnowledgeChunk[]     @relation("ChunkHistory")

  // Knowledge Graph Readiness (Schema support only, no implementation)
  parentChunkId        String?
  parentChunk          KnowledgeChunk?      @relation("ChunkHierarchy", fields: [parentChunkId], references: [id], onDelete: SetNull)
  childChunks          KnowledgeChunk[]     @relation("ChunkHierarchy")
  relatedBusinessDomains String[]
  referencedEntities     String[]

  // Growth Twin Tagging (Sprint 6)
  growthDomain          String?   // GrowthDomain enum value
  businessEngine        String?   // Engine ID e.g. 'marketing-engine'
  businessFunction      String?   // e.g. 'marketing-operations'
  lifecycleStage        String?   // BusinessStage value
  decisionType          String?   // 'STRATEGIC' | 'TACTICAL' | 'OPERATIONAL'
  chunkPriority         String?   // 'CRITICAL' | 'HIGH' | 'MEDIUM' | 'LOW'
  businessObjective     String?   // Free-text objective this supports
  relatedKpiSlugs       String[]  // KPI IDs this chunk informs
  futureDebateTopic     String?   // Future Debate Engine categorization
  futureRecommCategory  String?   // Future recommendation bucket

  metadata             KnowledgeMetadata[]
  embeddingRefs        EmbeddingReference[]

  @@index([businessId])
}

model KnowledgeMetadata {
  id             String         @id @default(uuid())
  chunkId        String
  chunk          KnowledgeChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  key            String
  value          String

  @@unique([chunkId, key])
}

model EmbeddingReference {
  id               String         @id @default(uuid())
  chunkId          String
  chunk            KnowledgeChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  chromaCollection String
  chromaDocumentId String
  embeddingModel   String
  embeddingVersion String
  createdAt        DateTime       @default(now())
  lastIndexedAt    DateTime       @updatedAt

  @@index([chunkId])
}

model KnowledgeCollection {
  id             String     @id @default(uuid())
  businessId     String
  business       Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name           String     // Business Core, Website, Financial, Marketing, Sales, Operations, etc.
  description    String?
  sourceType     SourceType
  status         String     // ACTIVE, ARCHIVED
  createdAt      DateTime   @default(now())

  @@index([businessId])
}

model KnowledgeStatistics {
  id                   String   @id @default(uuid())
  businessId           String   @unique
  business             Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  indexedDocs          Int      @default(0)
  indexedPages         Int      @default(0)
  totalChunks          Int      @default(0)
  approvedCount        Int      @default(0)
  pendingCount         Int      @default(0)
  freshnessScore       Float    @default(100.0)
  coverageScore        Float    @default(0.0)
  sourceDiversityScore Float    @default(0.0)
  versionHealthScore   Float    @default(100.0)
  reviewHealthScore    Float    @default(100.0)
  outdatedDocsCount    Int      @default(0)
  outdatedPagesCount   Int      @default(0)
  knowledgeGapsCount   Int      @default(0)
  updatedAt            DateTime @updatedAt
}

model KnowledgeVersion {
  id             String   @id @default(uuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  entityType     String   // e.g. "DOCUMENT", "WEBSITE"
  entityId       String   // e.g. Document ID or Website ID
  versionNumber  Int
  hash           String
  createdAt      DateTime @default(now())

  @@index([businessId])
}

model ContextSnapshot {
  id                 String   @id @default(uuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  timestamp          DateTime @default(now())
  contextVersion     Int
  digitalTwinVersion Int
  knowledgeVersion   Int
  sourcesUsed        String[] // List of source IDs
  confidenceSummary  Float
  topic              String   // e.g. "Marketing"
  payload            String   @db.Text // Structured JSON snapshot payload
  createdAt          DateTime @default(now())

  @@index([businessId])
}

enum ChunkStatus {
  ACTIVE
  STALE
  ARCHIVED
}

// ==========================================
// GROWTH DIGITAL TWIN LAYER — SPRINT 6
// ==========================================

enum GrowthDomain {
  BUSINESS_FOUNDATION
  MARKET_POSITION
  BRAND_POSITIONING
  PRODUCT_PORTFOLIO
  CUSTOMER_SEGMENTS
  CUSTOMER_PERSONAS
  MARKETING
  LEAD_GENERATION
  SALES
  CUSTOMER_SUCCESS
  COMPETITORS
  PRICING
  GROWTH_METRICS
  BUSINESS_GOALS
  BUSINESS_CONSTRAINTS
  RISKS
  GROWTH_OPPORTUNITIES
}

enum BusinessStage {
  PRE_LAUNCH
  EARLY_STAGE
  GROWTH
  SCALE
  ENTERPRISE
  TURNAROUND
}

enum BusinessModelType {
  B2B
  B2C
  B2B2C
  MARKETPLACE
  SAAS
  ECOMMERCE
  SERVICES
  HYBRID
}

model GrowthDomainState {
  id                     String       @id @default(uuid())
  businessId             String
  business               Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  domain                 GrowthDomain
  currentState           String?      @db.Text  // JSON
  desiredState           String?      @db.Text  // JSON
  gap                    String?      @db.Text  // JSON computed gap
  gapSeverity            String       @default("NONE") // NONE | LOW | MEDIUM | HIGH | CRITICAL
  priority               Int          @default(50)     // 1-100
  confidence             Float        @default(0.0)    // 0-100
  evidenceIds            String[]
  knowledgeSources       String[]
  dependencies           String[]     // other GrowthDomain slugs
  futureAIRecommendations String?     @db.Text
  lastUpdated            DateTime     @default(now())
  version                Int          @default(1)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  history                GrowthDomainHistory[]

  @@unique([businessId, domain])
  @@index([businessId])
}

model GrowthDomainHistory {
  id            String           @id @default(uuid())
  domainStateId String
  domainState   GrowthDomainState @relation(fields: [domainStateId], references: [id], onDelete: Cascade)
  businessId    String
  domain        GrowthDomain
  snapshot      String           @db.Text // Full JSON snapshot
  version       Int
  changedBy     String           // USER | WEBSITE_SYNC | DOCUMENT_SYNC | AI
  createdAt     DateTime         @default(now())

  @@index([businessId])
  @@index([domainStateId])
}

model GrowthTwinSummary {
  id                String           @id @default(uuid())
  businessId        String           @unique
  business          Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  overallConfidence Float            @default(0.0)
  coveredDomains    Int              @default(0)
  totalDomains      Int              @default(17)
  highGapDomains    String[]
  lastSyncedAt      DateTime         @default(now())
  sectorSlug        String?          // references SectorConfig.slug
  businessStage     BusinessStage    @default(EARLY_STAGE)
  businessModelType BusinessModelType @default(B2B)
  updatedAt         DateTime         @updatedAt
}

model AIOperatingContext {
  id                String   @id @default(uuid())
  businessId        String   @unique
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  activeGoals       String?  @db.Text // JSON array
  currentPriorities String?  @db.Text // JSON array
  currentChallenges String?  @db.Text // JSON array
  activeExperiments String?  @db.Text // JSON array
  strategicFocus    String?  @db.Text // JSON
  engineOutputs     String?  @db.Text // JSON: {engineId -> lastOutput}
  pendingDecisions  String?  @db.Text // JSON array
  contextVersion    Int      @default(1)
  lastUpdatedBy     String   @default("USER") // USER or engine ID
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model SectorConfig {
  id                        String   @id @default(uuid())
  slug                      String   @unique
  displayName               String
  description               String   @db.Text
  businessTerminology       String   @db.Text // JSON
  kpiSlugs                  String[]
  requiredDiscoveryDomains  String[]
  marketingChannels         String[]
  leadGenerationChannels    String[]
  salesProcessSteps         String[]
  customerSuccessMetrics    String[]
  competitiveDimensions     String[]
  questionPriorities        String   @db.Text // JSON: {questionId -> priority}
  growthConstraints         String[]
  businessLifecycle         String   @db.Text // JSON
  customerJourney           String   @db.Text // JSON
  marketingFunnel           String   @db.Text // JSON
  salesFunnel               String   @db.Text // JSON
  commonPainPoints          String[]
  buyingBehaviour           String   @db.Text // JSON
  commonRisks               String[]
  typicalKpis               String[]
  typicalCompetitors        String   @db.Text // JSON
  growthBottlenecks         String[]
  typicalAIOpportunities    String[]
  futureAIPromptTemplates   String   @db.Text // JSON: {engineId -> template}
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}


