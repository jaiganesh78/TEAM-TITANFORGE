model RevenuePipeline {
  id         String                 @id @default(uuid())
  businessId String
  business   Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  stages     RevenuePipelineStage[]
  leads      LeadProfile[]
  histories  RevenuePipelineHistory[]

  @@index([businessId])
}

model RevenuePipelineStage {
  id                  String                 @id @default(uuid())
  pipelineId          String
  pipeline            RevenuePipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stageName           String                 // Prospect, Engaged, MQL, SQL, Discovery, Proposal, Negotiation, Closed Won, Customer Success
  entryCriteria       String                 @db.Text
  exitCriteria        String                 @db.Text
  probability         Float
  averageTimeDays     Int
  bottlenecks         String                 @db.Text
  risks               String                 @db.Text
  requiredDocuments   String                 @db.Text // JSON string list
  requiredActivities  String                 @db.Text // JSON string list
  responsibleEngine   String                 // marketing-engine, lead-engine, sales-engine
  recommendedActions  String                 @db.Text // JSON string list
  leads               LeadProfile[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([pipelineId])
  @@index([businessId])
}

model RevenuePipelineHistory {
  id            String                 @id @default(uuid())
  pipelineId    String
  pipeline      RevenuePipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  businessId    String
  business      Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadId        String
  lead          LeadProfile            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStage     String
  toStage       String
  movedAt       DateTime               @default(now())
  durationDays  Int?

  @@index([pipelineId])
  @@index([businessId])
  @@index([leadId])
}

model LeadSession {
  id                  String                   @id @default(uuid())
  businessId          String
  business            Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  status              SessionStatus            @default(IN_PROGRESS)
  contextSnapshotId   String?
  contextSnapshot     ContextSnapshot?         @relation(fields: [contextSnapshotId], references: [id])
  contextVersion      Int                      @default(1)
  promptVersion       String                   @default("1.0.0")
  modelVersion        String                   @default("gemini-2.5-pro")

  // Subgraph Outputs (serialized JSON)
  icpAnalysis         String?                  @db.Text
  leadSources         String?                  @db.Text
  acquisitionPlan     String?                  @db.Text
  qualificationRules  String?                  @db.Text
  scoringModel        String?                  @db.Text
  segmentation        String?                  @db.Text
  nurtureJourneys     String?                  @db.Text
  forecasts           String?                  @db.Text
  executiveScores     String?                  @db.Text

  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  leads               LeadProfile[]
  leadSourcesList     LeadSource[]
  leadScores          LeadScore[]
  leadJourneys        LeadJourney[]
  recommendations     LeadRecommendation[]
  forecastsList       LeadForecast[]
  playbooks           LeadPlaybook[]
  feedbacks           LeadFeedback[]
  executionPlans      LeadExecutionPlan[]
  evidences           LeadEvidence[]
  histories           LeadHistory[]
  executionLogs       LeadGraphExecutionLog[]
  nodeOutputs         LeadGraphNodeOutput[]

  @@index([businessId])
}

model LeadProfile {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  pipelineId          String
  pipeline            RevenuePipeline        @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId             String
  stage               RevenuePipelineStage   @relation(fields: [stageId], references: [id], onDelete: Cascade)

  companyName         String
  industry            String
  companySize         String
  revenueRange        String
  decisionMakers      String                 @db.Text // JSON string list
  painPoints          String                 @db.Text // JSON string list
  techStack           String                 @db.Text // JSON string list
  buyingIntent        String                 // HIGH, MEDIUM, LOW
  budgetLevel         Float
  growthStage         String
  expectedLtv         Float
  expectedCac         Float
  confidence          Float
  evidence            String                 @db.Text
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  scores              LeadScore[]
  journeys            LeadJourney[]
  recommendations     LeadRecommendation[]
  pipelineHistories   RevenuePipelineHistory[]

  @@index([sessionId])
  @@index([businessId])
  @@index([pipelineId])
  @@index([stageId])
