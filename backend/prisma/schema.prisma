model LeadSource {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sourceName          String                 // LinkedIn, Google Search, Referrals, etc.
  rank                Int
  expectedRoi         String
  difficulty          String
  requiredBudget      Float
  expectedLeads       Int
  confidence          Float
  evidence            String                 @db.Text
  createdAt           DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
}

model LeadScore {
  id                    String                 @id @default(uuid())
  sessionId             String
  session               LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId            String
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadId                String
  lead                  LeadProfile            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  fitScore              Float
  intentScore           Float
  budgetScore           Float
  authorityScore        Float
  needScore             Float
  timingScore           Float
  overallQualification  Float

  qualityScore          Float
  valueScore            Float
  conversionProbability Float
  revenuePotential      Float
  riskScore             Float
  urgencyScore          Float
  priorityTier          String                 // Tier 1, Tier 2, Tier 3

  explainability        String                 @db.Text // JSON text
  createdAt             DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
  @@index([leadId])
}

model LeadJourney {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadId              String?
  lead                LeadProfile?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  journeyType         String                 // Cold, Warm, Hot, Enterprise, SMB
  touchpoints         String                 @db.Text // JSON list of touchpoints
  messages            String                 @db.Text // JSON list of messages
  waitingPeriods      String                 @db.Text // JSON list of waiting periods
  successKpis         String                 @db.Text // JSON list of KPIs
  createdAt           DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
  @@index([leadId])
}

model LeadRecommendation {
  id                    String                 @id @default(uuid())
  sessionId             String
  session               LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId            String
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadId                String?
  lead                  LeadProfile?           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  title                 String
  nextBestAction        String                 @db.Text
  expectedCloseProb     Float
  expectedTimeline      String
  riskFactors           String                 @db.Text // JSON string list
  dependencies          String                 @db.Text // JSON string list
  alternativeActions    String                 @db.Text // JSON string list
  status                String                 @default("PENDING") // PENDING, APPROVED, REJECTED
  
  feedbacks             LeadFeedback[]
  executionPlans        LeadExecutionPlan[]
  evidences             LeadEvidence[]
  createdAt             DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
  @@index([leadId])
}

model LeadForecast {
  id                    String                 @id @default(uuid())
  sessionId             String
  session               LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId            String
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)

  expectedLeads         Int
  qualifiedLeads        Int
  sqlCount              Int
  conversionRate        Float
  revenue               Float
  pipelineValue         Float
  confidenceMin         Float
  confidenceMax         Float
  createdAt             DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
}

model LeadPlaybook {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name                String
  playRules           String                 @db.Text // JSON rules
  targetAudience      String
  triggerCondition    String
  recommendedSteps    String                 @db.Text // JSON steps
  createdAt           DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
}

model LeadMemory {
  id                  String                 @id @default(uuid())
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  acceptedStrategies  String                 @db.Text // JSON list
  rejectedStrategies  String                 @db.Text // JSON list
  performanceLogs     String                 @db.Text // JSON performance metrics
  createdAt           DateTime               @default(now())

  @@index([businessId])
}

model LeadFeedback {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recommendationId    String
  recommendation      LeadRecommendation     @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  action              String                 // ACCEPT, REJECT, REGENERATE
  feedbackText        String?                @db.Text
  createdAt           DateTime               @default(now())

  @@index([sessionId])
  @@index([recommendationId])
  @@index([businessId])
}

model LeadExecutionPlan {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recommendationId    String
  recommendation      LeadRecommendation     @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  steps               String                 @db.Text // JSON tasks list
  status              String                 @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([sessionId])
  @@index([recommendationId])
  @@index([businessId])
}

model LeadEvidence {
  id                    String                 @id @default(uuid())
  sessionId             String
  session               LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recommendationId      String?
  recommendation        LeadRecommendation?    @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  businessId            String
  business              Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  factPath              String
  factValue             String
  confidence            Float
  createdAt             DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
}

model LeadHistory {
  id                  String                 @id @default(uuid())
  sessionId           String
  session             LeadSession            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  businessId          String
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  leadId              String
  oldStage            String
  newStage            String
  updatedBy           String                 // user or engine name
  updatedAt           DateTime               @default(now())

  @@index([sessionId])
  @@index([businessId])
}

model LeadGraphExecutionLog {
  id               String          @id @default(uuid())
  sessionId        String
  session          LeadSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  startedAt        DateTime        @default(now())
  finishedAt       DateTime?
  totalDurationMs  Int             @default(0)
  status           String          // SUCCESS | FAILED
  failureReason    String?         @db.Text
  nodeTraces       String?         @db.Text // JSON string
  createdAt        DateTime        @default(now())

  @@index([sessionId])
}

model LeadGraphNodeOutput {
  id             String          @id @default(uuid())
  sessionId      String
  session        LeadSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  nodeName       String
  inputSize      Int
  outputSize     Int
  durationMs     Int
  attempts       Int             @default(1)
  payload        String          @db.Text // JSON output
  reflectionRuns Int             @default(0)
  createdAt      DateTime        @default(now())

  @@index([sessionId])
}





