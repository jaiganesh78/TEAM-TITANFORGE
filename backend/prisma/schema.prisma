  quarterGoals           String                @db.Text // JSON list
  strategicInitiatives   String                @db.Text // JSON list
  operationalInitiatives String                @db.Text // JSON list
  revenueInitiatives     String                @db.Text // JSON list
  customerInitiatives    String                @db.Text // JSON list
  innovationInitiatives  String                @db.Text // JSON list
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([sessionId])
  @@index([businessId])
}

model ExecutiveRoadmap {
  id                String                @id @default(uuid())
  sessionId         String
  businessId        String
  phase             String // NOW, NEXT, LATER
  itemText          String
  businessValue     String                @db.Text
  risk              String                @db.Text
  confidence        Float
  requiredResources String                @db.Text // JSON list
  dependencies      String                @db.Text // JSON list
  status            String                @default("PLANNED")
  createdAt         DateTime              @default(now())

  @@index([sessionId])
  @@index([businessId])
}

model DiscoveryChatSession {
  id                String             @id @default(uuid())
  businessId        String             @unique
  status            String             // IN_PROGRESS, COMPLETED
  currentPhase      String             // IDENTITY, PRODUCTS, CUSTOMERS, etc.
  currentDomain     String?
  overallConfidence Float              @default(0.0)
  startedAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  messages          DiscoveryMessage[]
}

model DiscoveryMessage {
  id                String               @id @default(uuid())
  sessionId         String
  session           DiscoveryChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role              String               // assistant, user
  content           String               @db.Text
  questionId        String?
  domain            String?
  confidenceBefore  Float?
  confidenceAfter   Float?
  reasonForQuestion String?              @db.Text
  createdAt         DateTime             @default(now())
}

model DiscoveryJob {
  id          String   @id @default(uuid())
  taskType    String   // WEBSITE_CRAWL, DOC_PARSING, ENGINE_RUN, etc.
  payload     String   @db.Text // JSON
  status      String   // PENDING, PROCESSING, COMPLETED, FAILED
  error       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIMemory {
  id          String   @id @default(uuid())
  businessId  String
  layer       String   // CONVERSATION, WORKING, BUSINESS, DECISION, LONG_TERM
  key         String
  value       String   @db.Text // JSON or plain text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessId, layer, key])
  @@index([businessId])
}

